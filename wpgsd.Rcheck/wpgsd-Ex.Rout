> cleanEx()
> nameEx("find_astar")
> ### * find_astar
> 
> flush(stderr()); flush(stdout())
> 
> ### Name: find_astar
> ### Title: Utility function for root-finding to compute crossing
> ###   probabilities with the overall alpha spending approach
> ### Aliases: find_astar
> 
> ### ** Examples
> 
> # Input event count of intersection of paired hypotheses - Table 2
> my_event <- tibble::tribble(
+   ~H1, ~H2, ~Analysis, ~Event,
+   1, 1, 1, 155,
+   2, 2, 1, 160,
+   3, 3, 1, 165,
+   1, 2, 1, 85,
+   1, 3, 1, 85,
+   2, 3, 1, 85,
+   1, 1, 2, 305,
+   2, 2, 2, 320,
+   3, 3, 2, 335,
+   1, 2, 2, 170,
+   1, 3, 2, 170,
+   2, 3, 2, 170
+ )
> 
> # Generate correlation from events
> my_corr <- generate_corr(my_event)
> 
> # Find the inflation factor for H1, H2 at analysis 1
> find_astar(
+   a = 0.0008708433,
+   alpha_prev = NULL,
+   aprime = c(0.0004588644, 0.0004119789),
+   astar = 1,
+   w = c(0.5, 0.5),
+   sig = my_corr[
+     colnames(my_corr) %in% c("H1_A1", "H2_A1"),
+     colnames(my_corr) %in% c("H1_A1", "H2_A1")
+   ]
+ )
[1] 0.6583884
attr(,"error")
[1] 1e-15
attr(,"msg")
[1] "Normal Completion"
> 
> 
> 
> cleanEx()
> nameEx("find_xi")
> ### * find_xi
> 
> flush(stderr()); flush(stdout())
> 
> ### Name: find_xi
> ### Title: Utility function for root-finding to compute inflation factor xi
> ###   with the separate alpha spending approach
> ### Aliases: find_xi
> 
> ### ** Examples
> 
> # Input event count of intersection of paired hypotheses - Table 2
> my_event <- tibble::tribble(
+   ~H1, ~H2, ~Analysis, ~Event,
+   1, 1, 1, 155,
+   2, 2, 1, 160,
+   3, 3, 1, 165,
+   1, 2, 1, 85,
+   1, 3, 1, 85,
+   2, 3, 1, 85,
+   1, 1, 2, 305,
+   2, 2, 2, 320,
+   3, 3, 2, 335,
+   1, 2, 2, 170,
+   1, 3, 2, 170,
+   2, 3, 2, 170
+ )
> 
> # Generate correlation from events
> my_corr <- generate_corr(my_event)
> 
> # Find the inflation factor for H1, H2 at analysis 1
> find_xi(
+   a = 0.0008708433,
+   alpha_prev = NULL,
+   aprime = c(0.0004588644, 0.0004119789),
+   xi = 1,
+   sig = my_corr[
+     colnames(my_corr) %in% c("H1_A1", "H2_A1"),
+     colnames(my_corr) %in% c("H1_A1", "H2_A1")
+   ]
+ )
[1] -2.237679e-05
attr(,"error")
[1] 1e-15
attr(,"msg")
[1] "Normal Completion"
> 
